# ── Local ──────────────────────────────────────────────────────────────────
PORT=3004
BASE_URL=http://localhost:3004

# ── Railway (se configura en el dashboard de Railway) ──────────────────────
# PORT        → Railway lo asigna automáticamente, no tocar
# BASE_URL    → URL pública que Railway genera, ej: https://bosskin.up.railway.app
# DATA_DIR    → Ruta del volumen persistente, ej: /data

# ── Mercado Pago ───────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.cl/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# ── Admin panel ────────────────────────────────────────────────────────────
ADMIN_PASSWORD=boosskin2025

# ── Editor de Video: transcripción con Groq Whisper (gratis) ────────────────
# Consíguela gratis en https://console.groq.com  →  API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── Emails con Resend (https://resend.com) ──────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Email donde Barbara recibe notificaciones de nuevas reservas
NOTIFICATION_EMAIL=barbara@bosskinlab.com
